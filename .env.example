# UPS API credentials (required)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=

# UPS retry policy (optional, shown with defaults)
# UPS_MAX_ATTEMPTS=4
# UPS_BASE_DELAY_MS=200
# UPS_TIMEOUT_MS=3000
# UPS_MAX_RETRY_AFTER_SECONDS=5

# UPS endpoint URLs (optional, shown with production defaults)
# UPS_RATING_URL=https://onlinetools.ups.com/api/rating/v2409/Shoptimeintransit
# UPS_TOKEN_URL=https://onlinetools.ups.com/security/v1/oauth/token

# UPS token expiry buffer (optional, shown with default)
# UPS_TOKEN_EXPIRY_BUFFER_SECONDS=60
